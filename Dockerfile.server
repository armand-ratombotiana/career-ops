FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY lib/ ./lib/
COPY config/ ./config/
COPY templates/ ./templates/
COPY fonts/ ./fonts/
COPY server.mjs ./

ENV PORT=3001
ENV HOST=0.0.0.0
EXPOSE 3001

VOLUME [ "/app/data", "/app/reports", "/app/output", "/app/interview-prep", "/app/jds" ]

CMD ["node", "server.mjs"]
